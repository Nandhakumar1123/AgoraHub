# Server
PORT=3000

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d

# CORS (pick the origin of your Expo app; for dev you can also use "*")
# Examples:
# CORS_ORIGIN=http://192.168.1.10:19006
# CORS_ORIGIN=*
CORS_ORIGIN=*

# PostgreSQL (Supabase) - Option A: use DATABASE_URL
#DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require

# PostgreSQL (Supabase) - Option B: use individual fields
DB_HOST=YOUR_DB_HOST
DB_PORT=5432
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# Supabase usually needs SSL
DB_SSL=true

